---
import ProjectCard from "./ProjectCard.astro";

import KanbanProjectScreenshot from "../assets/kanban-project-screenshot.png";
import MiniProjectsScreenshot from "../assets/mini-projects-screenshot.png";

const projectImages: Record<string, ImageMetadata> = {
  "kanban-board": KanbanProjectScreenshot,
  "mini-projects-website": MiniProjectsScreenshot,
};

const res = await fetch("https://api.github.com/users/yinchurijnaard/repos", {
  headers: {
    Authorization: `token ${import.meta.env.GITHUB_PAT}`,
    "User-Agent": "Astro-Portfolio-App",
    Accept: "application/vnd.github+json",
  },
});

const rawRepos = await res.json();

const myRepos = rawRepos
  .filter(
    (repo: { fork: any; topics: string | string[] }) =>
      !repo.fork && repo.topics.includes("portfolio"),
  )
  .map(
    (repo: {
      id: number;
      name: string;
      stargazers_count: number;
      language: string;
      description: string;
      html_url: string;
      thumbnail: any;
    }) => ({
      id: repo.id,
      name: repo.name,
      title: repo.name.replace(/-/g, " "),
      stars: repo.stargazers_count,
      language: repo.language || "N/A",
      description: repo.description,
      url: repo.html_url,
      thumbnail: projectImages[repo.name] || null,
    }),
  )
  .sort((a: { stars: number }, b: { stars: number }) => b.stars - a.stars);
---

<div class="flex flex-col gap-4 border border-blue-500">
  <!-- TITLE -->
  <div>
    <p
      class="bg-linear-to-r from-rose-500 via-emerald-500 to-rose-500 bg-clip-text text-2xl font-black tracking-tighter text-transparent sm:text-4xl"
    >
      Projects
    </p>
  </div>

  <!-- REPOSITORIES SHOWCASE -->
  <div
    class="mx-auto grid max-w-4xl grid-cols-1 gap-8 px-6 py-10 md:grid-cols-2"
  >
    {
      myRepos.map((repo: any) => (
        <>
          <ProjectCard
            key={repo.id}
            title={repo.name}
            description={repo.description}
            url={repo.url}
            imgSrc={repo.thumbnail}
          />
        </>
      ))
    }
  </div>
</div>
